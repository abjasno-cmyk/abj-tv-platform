{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/program/v3/refresh-cache",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/program/v3/import-feed",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/newsletter/daily",
      "schedule": "0 6 * * *"
    }
  ]
}
