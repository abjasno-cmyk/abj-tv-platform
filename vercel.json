{
  "framework": "nextjs",
  "buildCommand": "next build",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/program/v3/refresh-cache",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/program/v3/import-feed",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/noviny/import",
      "schedule": "*/20 * * * *"
    },
    {
      "path": "/api/noviny/context/analyze",
      "schedule": "7 * * * *"
    },
    {
      "path": "/api/noviny/enrich",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/search/index",
      "schedule": "17 * * * *"
    }
  ]
}
